<Window x:Class="IslandCaller.App.Views.Windows.HoverFluent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:IslandCaller.App.Views.Windows"
        xmlns:models="clr-namespace:IslandCaller.App.Models"
        xmlns:controls="clr-namespace:IslandCaller.App.Controls.HoverFluent"
        d:DataContext="{d:DesignInstance Type=models:Settings}"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="#01FFFFFF"
        Topmost="True"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Acrylic"
        Title="Hover" Height="70" Width="163"
        SourceInitialized="Window_SourceInitialized" 
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        AllowDrop="True">
    <Grid>
        <Button
            x:Name="MainButton"
            Style="{DynamicResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}"
            Margin="10,0,0,0"
            Height="50"
            Width="85"
            Background="#BF8A73D6"
            Foreground="White"
            Click="MainButton_Click" 
            MouseOverBackground="#E5715DC4" 
            PressedBackground="#FF4E3BAB" 
            Focusable="False" 
            PressedForeground="White"
            Padding="4"
            PreviewMouseLeftButtonDown="MainButton_PreviewMouseLeftButtonDown">
            <controls:HoverMainButton x:Name="img" HorizontalAlignment="Center" VerticalAlignment="Center" Height="40"/>
        </Button>
        <ui:Button
            x:Name="Secondary_Button"
            Appearance="Secondary"
            Margin="102,0,0,0"
            Height="50"
            Width="50" 
            Background="#4C808080"
            Padding="4"
            Click="SecondaryButton_Click"
            PreviewMouseLeftButtonDown="SecondaryButton_PreviewMouseLeftButtonDown">
            <controls:HoverSecondaryButton HorizontalAlignment="Center" VerticalAlignment="Center" Height="40"/>
        </ui:Button>
    </Grid>
</Window>
